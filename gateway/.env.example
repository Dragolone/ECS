# ========== HTTP 服务 ==========
HTTP_HOST=0.0.0.0
HTTP_PORT=8090

# ========== MQTT 连接（同时用于订阅遥测 + 发布指令） ==========
MQTT_HOST=43.139.45.139
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=

# 命令发布前缀（如 01_test → 01_test/status, 01_test/move）
MQTT_BASE_PREFIX=01_test

# 遥测订阅主题（默认 = {MQTT_BASE_PREFIX}/Servers）
MQTT_SUB_TOPIC=01_test/Servers

# publish 等待确认超时（秒）
MQTT_PUBLISH_TIMEOUT_SECONDS=3

# ========== 鉴权 ==========
# 云函数 sendCommand 鉴权 Header: x-command-token
COMMAND_TOKEN=abc123

# 小程序 WebSocket 连接鉴权（不填则使用 COMMAND_TOKEN）
WS_TOKEN=abc123

# ========== 遥测写库（uniCloud telemetryIngest） ==========
# 不填则仅通过 WebSocket 推送，不写库
INGEST_URL=https://fc-mp-ffb47fea-af23-40cb-a482-598fb3315226.next.bspapp.com/telemetryIngest
INGEST_TOKEN=abc123
HTTP_TIMEOUT_SECONDS=8
HTTP_MAX_RETRIES=3

# ========== 去重 ==========
DEDUP_ENABLED=1
DEDUP_TTL_SECONDS=30
DEDUP_MAX_KEYS=50000
